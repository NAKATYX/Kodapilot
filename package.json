{
  "name": "kodapilot",
  "version": "0.1.0",
  "description": "AI-native trust-commerce network on 0G",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm --filter=@kodapilot/shared --filter=@kodapilot/web --filter=@kodapilot/api run build",
    "build:all": "pnpm -r run build",
    "start": "node server.js",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=6.35.0"
  },
  "packageManager": "pnpm@9.1.0"
}
